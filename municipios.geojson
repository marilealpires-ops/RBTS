
:root{
  --azul-sus:#005eb8;
  --azul-escuro:#063970;
  --verde-sus:#00a859;
  --amarelo:#ffd166;
  --bg:#eef6fb;
  --card:#ffffffee;
  --texto:#153243;
  --muted:#5e7482;
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
  background: radial-gradient(circle at 20% 0%, #dff7ff 0, #eef6fb 32%, #f8fbff 100%);
  color:var(--texto);
  overflow:hidden;
}
.app-header{
  height:92px;
  padding:12px 18px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16px;
  background:linear-gradient(135deg, #005eb8 0%, #0077cc 45%, #00a859 100%);
  color:white;
  box-shadow:0 8px 24px rgba(0,0,0,.18);
  position:relative;
  z-index:1000;
}
.brand{display:flex; align-items:center; gap:14px; min-width:360px}
.sus-logo{
  width:92px; height:54px; object-fit:contain;
  filter:drop-shadow(0 6px 8px rgba(0,0,0,.2));
}
h1{font-size:26px; line-height:1.05; margin:0; letter-spacing:.2px}
.brand p{margin:4px 0 0; color:#e7f7ff; font-size:13px}
.header-actions{
  display:flex; align-items:center; gap:9px; flex-wrap:wrap; justify-content:flex-end;
}
.header-actions label{font-size:12px; font-weight:700; opacity:.95}
select,input,button{
  border:0; outline:0; border-radius:999px; padding:10px 14px; font-size:14px;
  box-shadow:0 3px 12px rgba(0,0,0,.15);
}
select{min-width:120px; cursor:pointer; background:white}
input{min-width:300px}
button{
  background:#ffca3a; color:#17324d; font-weight:800; cursor:pointer;
  transition:.2s transform,.2s filter;
}
button:hover{transform:translateY(-1px); filter:brightness(1.05)}
main{height:calc(100vh - 122px); position:relative}
#map{height:100%; width:100%; background:#dfeefa}
footer{
  height:30px; display:flex; align-items:center; justify-content:center;
  color:#335; background:#ffffffd9; font-size:13px; box-shadow:0 -4px 16px rgba(0,0,0,.07);
  position:relative; z-index:1000;
}
.info-card{
  position:absolute; left:18px; bottom:86px; z-index:900;
  max-width:360px; padding:16px 18px;
  background:var(--card); backdrop-filter: blur(8px);
  border-radius:18px; box-shadow:0 12px 30px rgba(0,0,0,.16);
  border:1px solid rgba(0,94,184,.12);
}
.info-title{font-size:18px; font-weight:900; color:var(--azul-escuro); margin-bottom:6px}
.info-body{font-size:13px; color:var(--muted); line-height:1.42}
.legend{
  position:absolute; right:18px; bottom:86px; z-index:900;
  background:var(--card); backdrop-filter: blur(8px);
  border-radius:18px; padding:14px 16px; min-width:270px;
  box-shadow:0 12px 30px rgba(0,0,0,.16);
  border:1px solid rgba(0,94,184,.12);
  font-size:13px; line-height:1.8;
}
.legend h2{font-size:15px; margin:0 0 6px; color:var(--azul-escuro)}
.legend-dot{
  display:inline-block; width:16px; height:16px; border-radius:50%;
  background:linear-gradient(135deg,#005eb8,#00a859);
  border:3px solid white; box-shadow:0 0 0 3px rgba(0,94,184,.3); vertical-align:middle; margin-right:8px;
}
.legend-box{display:inline-block;width:17px;height:13px;margin-right:8px;vertical-align:-2px;border-radius:3px}
.legend-box.municipios{background:#00a859;border:2px solid #063970}
.legend-box.uf{background:#ffd166;border:2px solid #f77f00}
.legend-line{display:inline-block;width:22px;border-top:3px solid #213547;margin-right:8px;vertical-align:middle}
.leaflet-popup-content-wrapper{
  border-radius:18px;
  box-shadow:0 16px 35px rgba(0,0,0,.25);
}
.popup-card{min-width:260px; max-width:360px}
.popup-title{
  font-weight:900; color:#063970; font-size:16px; line-height:1.2; margin-bottom:6px;
}
.popup-sub{color:#5e7482; font-size:12px; margin-bottom:10px}
.popup-grid{display:grid; grid-template-columns:92px 1fr; gap:6px 10px; font-size:12px}
.popup-grid b{color:#335}
.popup-actions{margin-top:12px}
.popup-button{
  display:block; text-align:center; padding:10px 12px; border-radius:999px;
  background:linear-gradient(135deg,#005eb8,#00a859); color:white!important; font-weight:900; text-decoration:none;
}
.uf-popup-list{max-height:260px; overflow:auto; padding-right:4px}
.uf-nucleo-link{
  display:block; padding:8px 9px; margin:6px 0; border-radius:10px;
  color:#063970!important; background:#eef6fb; text-decoration:none; font-weight:700;
  border-left:5px solid var(--cor);
}
.nucleo-marker{
  width:28px; height:28px; border-radius:50%;
  border:4px solid white;
  box-shadow:0 0 0 5px rgba(0,94,184,.22), 0 8px 18px rgba(0,0,0,.35);
  transition:.2s transform,.2s box-shadow;
}
.nucleo-marker:hover{
  transform:scale(1.18);
  box-shadow:0 0 0 7px rgba(255,202,58,.45), 0 12px 24px rgba(0,0,0,.4);
}
.nucleo-marker.active{
  box-shadow:0 0 0 8px rgba(255,202,58,.75), 0 16px 30px rgba(0,0,0,.45);
  transform:scale(1.22);
}
.search-box{
  background:white; padding:8px; border-radius:14px; box-shadow:0 8px 20px rgba(0,0,0,.18);
}
.search-result{
  display:block; padding:7px 9px; border-radius:10px; color:#063970; text-decoration:none; font-weight:700;
}
.search-result:hover{background:#eef6fb}
@media(max-width:900px){
  body{overflow:auto}
  .app-header{height:auto; align-items:flex-start; flex-direction:column}
  main{height:calc(100vh - 168px)}
  .brand{min-width:0}
  h1{font-size:21px}
  input{min-width:220px}
  .legend{right:10px; bottom:52px}
  .info-card{left:10px; bottom:52px; max-width:300px}
}
